{
  "name": "Gilbert Ecommerce",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "features": {
    "ghcr.io/devcontainers/features/mysql:1": {
      "version": "8.0",
      "rootPassword": "root"
    }
  },
  "forwardPorts": [3000, 3306],
  "portsAttributes": {
    "3000": { "label": "App", "onAutoForward": "openBrowser" },
    "3306": { "label": "MySQL" }
  },
  "postCreateCommand": "npm install && mysql -u root -proot < sql/schema.sql && cp .env.example .env",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "humao.rest-client",
        "cweijan.vscode-mysql-client2"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  }
}
